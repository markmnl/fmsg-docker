# ── Required ──────────────────────────────────────────────

# fmsg domain name this host serves
FMSG_DOMAIN=example.com

# Per-service database passwords (used by application services)
FMSGD_WRITER_PGPASSWORD=changeme
FMSGID_WRITER_PGPASSWORD=changeme

